{
  "name": "DC-Squoosh-designer",
  "version": "1.0.0",
  "description": "Automotive Design Compose Squoosh Designer",
  "scripts": {
    "build": "npm run clean && node build.js",
    "test": "jest",
    "lint": "eslint --ext .ts,.tsx --ignore-pattern node_modules .",
    "lint:fix": "eslint --ext .ts,.tsx --ignore-pattern node_modules --fix .",
    "format": "prettier --write '**/*.{ts,tsx,css,md}'",
    "watch": "npm run build -- --watch",
    "dist": "npm run build && mkdir -p dist-package && cd dist && zip -r ../dist-package/DC-Squoosh-designer-$(date +%Y%m%d-%H%M%S).zip . && cd ..",
    "clean": "rm -rf dist dist-package DC-Squoosh-designer.zip"
  },
  "author": "",
  "license": "",
  "devDependencies": {
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "^1.118.0",
    "@types/fabric": "^5.3.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "esbuild": "^0.25.11",
    "eslint": "^8.54.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:@figma/figma-plugins/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "project": "./tsconfig.json"
    },
    "root": true,
    "rules": {
      "@typescript-eslint/no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_",
          "caughtErrorsIgnorePattern": "^_"
        }
      ]
    }
  },
  "dependencies": {
    "figplug-ui-kit": "^1.0.1"
  }
}
